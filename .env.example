# watsonx Orchestrate Configuration Template
# Copy this file to .env and fill in your actual credentials

# Orchestrate Service URL
ORCHESTRATE_SERVICE_URL=https://api.ca-tor.watson-orchestrate.cloud.ibm.com/instances/YOUR_INSTANCE_ID

# Orchestrate API Key
ORCHESTRATE_API_KEY=your_api_key_here

# Orchestrate Environment Name
ORCHESTRATE_ENV_NAME=wx0-AWS

# Deployment Timeout (seconds)
WXO_AGENT_DEPLOYMENT_TIMEOUT=300