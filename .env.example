# AgentForge Configuration Template
# Copy this file to .env and fill in your actual credentials
# NEVER commit the .env file - it contains sensitive credentials

# ============================================================================
# watsonx Orchestrate Configuration (Required for deployment)
# ============================================================================

# Orchestrate Service URL
# Get from: https://cloud.ibm.com/resources
ORCHESTRATE_SERVICE_URL=https://api.ca-tor.watson-orchestrate.cloud.ibm.com/instances/YOUR_INSTANCE_ID

# Orchestrate API Key
# Get from: https://cloud.ibm.com/iam/apikeys
ORCHESTRATE_API_KEY=your_orchestrate_api_key_here

# Orchestrate Environment Name
ORCHESTRATE_ENV_NAME=wx0-AWS

# Deployment Timeout (seconds)
WXO_AGENT_DEPLOYMENT_TIMEOUT=300

# ============================================================================
# LLM Configuration (Choose ONE - Groq is recommended)
# ============================================================================

# ----------------------------------------------------------------------------
# Option 1: GroqCloud (RECOMMENDED - Simple, Fast, Free Tier)
# ----------------------------------------------------------------------------
# Get API key from: https://console.groq.com/keys
# No provisioning needed, works immediately
GROQ_API_KEY=your_groq_api_key_here

# ----------------------------------------------------------------------------
# Option 2: watsonx.ai (Requires IBM Cloud provisioning permissions)
# ----------------------------------------------------------------------------
# Only use if you have IBM Cloud Editor permissions
# Get from: https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=your_watsonx_api_key_here

# Get from: https://dataplatform.cloud.ibm.com/projects
# Requires permission to create projects
WATSONX_PROJECT_ID=your_project_id_here

# Service URL (optional, defaults to us-south)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ============================================================================
# Setup Instructions
# ============================================================================
#
# Quick Start (Groq - Recommended):
# 1. Copy this file: cp .env.example .env
# 2. Get Groq API key: https://console.groq.com/keys (free, instant)
# 3. Add GROQ_API_KEY to .env
# 4. Update api/routes.py to use: from groq_runner import generate_agent
# 5. Run: conda activate watsonx && orchestrate env activate wx0-AWS
#
# Alternative (watsonx.ai):
# 1. Copy this file: cp .env.example .env
# 2. Get IBM Cloud API key: https://cloud.ibm.com/iam/apikeys
# 3. Create watsonx.ai project: https://dataplatform.cloud.ibm.com/projects
# 4. Add WATSONX_API_KEY and WATSONX_PROJECT_ID to .env
# 5. Update api/routes.py to use: from watsonx_runner import generate_agent
# 6. Run: conda activate watsonx && orchestrate env activate wx0-AWS